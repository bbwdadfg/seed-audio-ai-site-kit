\name{seed_audio_ai_url}
\alias{seed_audio_ai_url}
\title{Build a Seed Audio AI URL}
\usage{
seed_audio_ai_url(path = "")
}
\arguments{
\item{path}{Optional path under the Seed Audio AI homepage.}
}
\value{
A canonical Seed Audio AI URL.
}
\description{
Builds a canonical Seed Audio AI URL.
}
\examples{
seed_audio_ai_url()
seed_audio_ai_url("text-to-speech")
}
